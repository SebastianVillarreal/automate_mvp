# Active SQL profile: local or vps
SQLSERVER_PROFILE=local

# Local SQL Server using SQL authentication.
SQLSERVER_LOCAL_AUTH=sql
SQLSERVER_LOCAL_HOST=localhost\MSSQLSERVER01
SQLSERVER_LOCAL_PORT=
SQLSERVER_LOCAL_DATABASE=ScraperDb
SQLSERVER_LOCAL_USER=sa
SQLSERVER_LOCAL_PASSWORD=your_local_sql_password
SQLSERVER_LOCAL_ENCRYPT=false
SQLSERVER_LOCAL_TRUST_CERT=true

# VPS / remote SQL Server using SQL authentication.
SQLSERVER_VPS_AUTH=sql
SQLSERVER_VPS_HOST=your-vps-host-or-ip
SQLSERVER_VPS_PORT=1433
SQLSERVER_VPS_DATABASE=ScraperDb
SQLSERVER_VPS_USER=your_sql_user
SQLSERVER_VPS_PASSWORD=your_sql_password
SQLSERVER_VPS_ENCRYPT=false
SQLSERVER_VPS_TRUST_CERT=true

# Optional backend port. The Chrome extension currently posts to localhost:3005.
PORT=3005
